{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Information about a completed purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "stripeSessionId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status"]
    },
    "Briefing": {
      "title": "Briefing",
      "description": "User briefing data for their digital card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "data": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "data"]
    },
    "Link": {
      "title": "Link",
      "description": "A link on the user's digital card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["userId", "title", "url"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "active"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          } 
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Service plan details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "excludedFeatures": { "type": "array", "items": { "type": "string" } },
        "active": { "type": "boolean" },
        "order": { "type": "integer" }
      },
      "required": ["name", "price", "active"]
    },
    "Config": {
      "title": "Config",
      "description": "System configuration settings",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["payment", "smtp"] },
        "settings": { "type": "object" }
      },
      "required": ["type", "settings"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "Customer feedback and testimonials",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "text", "status"]
    },
    "Delivery": {
      "title": "Delivery",
      "description": "Information about the delivery of the digital and physical card",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardLink": { "type": "string" },
        "trackingCode": { "type": "string" },
        "trackingUrl": { "type": "string" },
        "bonusPdfUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "production", "shipped", "delivered"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Purchase records"
    },
    "/briefings/{briefingId}": {
      "schema": "Briefing",
      "description": "User briefing data"
    },
    "/links/{linkId}": {
      "schema": "Link",
      "description": "User digital card links"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Service plans"
    },
    "/config/{configId}": {
      "schema": "Config",
      "description": "System configurations (Payment, SMTP)"
    },
    "/testimonials/{testimonialId}": {
      "schema": "Testimonial",
      "description": "Customer testimonials"
    },
    "/deliveries/{deliveryId}": {
      "schema": "Delivery",
      "description": "Card delivery information"
    }
  }
}
